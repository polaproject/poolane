# ============================================
# SUPABASE
# Lấy từ: Supabase Dashboard → Settings → API
# ============================================
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxx

# QUAN TRỌNG: chỉ dùng server-side, không bao giờ commit
SUPABASE_SERVICE_ROLE_KEY=eyJxxx

# ============================================
# DATABASE (Prisma)
# Lấy từ: Supabase Dashboard → Settings → Database → Connection string
# DATABASE_URL = pooler (port 6543) cho query thường
# DIRECT_URL = direct (port 5432) cho migrations
# ============================================
DATABASE_URL="postgresql://postgres.xxx:PASSWORD@aws-1-ap-southeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.xxx:PASSWORD@aws-1-ap-southeast-1.pooler.supabase.com:5432/postgres"

# ============================================
# EMAIL (Resend) — đã verify domain polaproject.com
# Lấy từ: resend.com → API Keys
# ============================================
RESEND_API_KEY=re_xxx
EMAIL_FROM=support@polaproject.com

# ============================================
# APP
# ============================================
NEXT_PUBLIC_APP_URL=https://poolane.vn
NEXT_PUBLIC_APP_DOMAIN=poolane.vn
NEXT_PUBLIC_SCHOOL_NAME=Poolane
TZ=Asia/Ho_Chi_Minh

# ============================================
# VIETQR — Thông tin tài khoản ngân hàng nhận tiền
# BIN code các ngân hàng: SETUP-AFTER-WAKE.md
# ============================================
BANK_BIN=970436
BANK_ACCOUNT_NO=0011234567890
BANK_ACCOUNT_NAME=NGUYEN VAN OWNER
BANK_DISPLAY_NAME=Vietcombank

# ============================================
# SEPAY — Webhook auto-confirm chuyển khoản (gói 99k/tháng)
# Random token 32 ký tự: openssl rand -hex 32
# ============================================
SEPAY_API_KEY=xxx

# ============================================
# WEB PUSH (VAPID)
# Generate: npx web-push generate-vapid-keys
# ============================================
NEXT_PUBLIC_VAPID_PUBLIC_KEY=BCxxx
VAPID_PRIVATE_KEY=xxx
VAPID_SUBJECT=mailto:support@polaproject.com

# ============================================
# CRON — Vercel cron auth
# Random 32 ký tự: openssl rand -hex 32
# ============================================
CRON_SECRET=xxx
